    <footer class="bg-light text-muted py-3 mt-5${empty footerClass ? '' : ' '}${footerClass}">
        <div class="container text-center">
            <small>Gobierno de Aragón - Sistema de Gestión de Comisiones</small>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
