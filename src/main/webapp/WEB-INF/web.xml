<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Formulario Comisiones</display-name>

    <!-- Servlet LDAP Lookup -->
    <servlet>
        <servlet-name>LdapLookupServlet</servlet-name>
        <servlet-class>com.comisiones.ldap.LdapLookupServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>LdapLookupServlet</servlet-name>
        <url-pattern>/ldapLookup</url-pattern>
    </servlet-mapping>

    <!-- Página de bienvenida -->
    <welcome-file-list>
        <welcome-file>index</welcome-file>
    </welcome-file-list>

    <!-- Orden explícito de filtros: AuthFilter primero, RolFilter después -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.comisiones.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>RolFilter</filter-name>
        <filter-class>com.comisiones.filter.RolFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RolFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

</web-app>